#!/bin/bash
# limpid-pretool-worktree-hook
# Limpid â€” Claude Code PreToolUse hook handler that intercepts the Bash
# tool's `git worktree add` invocations so the resulting worktree
# follows the active Project's `worktreePlacement` + `bootstrap` rules
# instead of Claude's ad-hoc choice.
#
# Anything that isn't a `git worktree add` (or that we can't parse with
# high confidence) falls through silently (exit 0). We *never* modify a
# tool call â€” the only failure mode we accept is "let Claude's original
# command run unchanged".
#
# Decision contract: when we intercept and create the worktree
# successfully we write a single-line context line to stderr and exit 2.
# Claude Code's PreToolUse spec treats exit 2 as "deny tool call, surface
# stderr to the model"; the line we emit tells the model where the
# worktree landed so its next step can `cd` there.

set -uo pipefail

# `jq` is required for state.json parsing. If it's absent we
# passthrough â€” never break Claude over a missing optional dep.
if ! command -v jq >/dev/null 2>&1; then
  exit 0
fi

PAYLOAD="$(cat 2>/dev/null || true)"
[ -z "$PAYLOAD" ] && exit 0

TOOL_NAME=$(printf '%s' "$PAYLOAD" | jq -r '.tool_name // empty')
[ "$TOOL_NAME" = "Bash" ] || exit 0

COMMAND=$(printf '%s' "$PAYLOAD" | jq -r '.tool_input.command // empty')
[ -z "$COMMAND" ] && exit 0

# Strict match: leading whitespace, then `git [...] worktree add ...`.
# We tolerate `git -C dir worktree add` and other early flags; we don't
# match anywhere `worktree add` could appear without it being the
# operation being run (e.g. inside a `|` pipeline downstream).
if ! printf '%s' "$COMMAND" | grep -Eq '^[[:space:]]*git[[:space:]]+([^|;&]+[[:space:]]+)*worktree[[:space:]]+add([[:space:]]|$)'; then
  exit 0
fi

# `LIMPID_AGENT_STATES_DIR` is set per-pane by `ClaudeShimLocator`. If
# we're not inside a Limpid pty there's no `state.json` to consult.
if [ -z "${LIMPID_AGENT_STATES_DIR:-}" ]; then
  exit 0
fi
STATE_JSON="$(dirname "$LIMPID_AGENT_STATES_DIR")/state.json"
[ -f "$STATE_JSON" ] || exit 0

CWD=$(printf '%s' "$PAYLOAD" | jq -r '.cwd // empty')
CWD="${CWD:-$PWD}"

# Find the project whose `rootURL` is a path-prefix of `cwd`. Swift's
# URL Codable adds a `file://` scheme and often a trailing slash; we
# strip both before comparing so `/Users/x/repo/` (project rootURL) and
# `/Users/x/repo` (cwd) match. We also guard the prefix check against
# `/Users/x/repo` matching `/Users/x/repo-other` by requiring either
# exact equality or a `/`-bounded subpath.
PROJECT_DATA=$(jq --arg cwd "$CWD" '
    [.projects[]?
     | (.rootURL | sub("^file://"; "") | sub("/$"; "")) as $root
     | select($cwd == $root or ($cwd | startswith($root + "/")))]
    | first // null
' "$STATE_JSON" 2>/dev/null)

if [ -z "$PROJECT_DATA" ] || [ "$PROJECT_DATA" = "null" ]; then
  # Not inside a registered Limpid project â€” passthrough.
  exit 0
fi

PROJECT_ROOT=$(printf '%s' "$PROJECT_DATA" \
  | jq -r '.rootURL | sub("^file://"; "") | sub("/$"; "")')

# Per-project opt-out. When the user flips "Apply to Claude" off in
# Project Settings we passthrough so Claude lands worktrees at its
# default location. We use `has()` rather than `// true` because jq's
# alternative operator treats `false` itself as missing â€” `false //
# true` evaluates to `true`, which would silently invert the toggle.
ROUTE_ENABLED=$(printf '%s' "$PROJECT_DATA" | jq -r '
  if has("routeClaudeWorktrees") then .routeClaudeWorktrees else true end
')
if [ "$ROUTE_ENABLED" != "true" ]; then
  exit 0
fi

# `WorktreePlacement` is encoded as a Swift Codable enum:
#   {"siblingPrefixed":{}}, {"insideHidden":{}}, {"custom":{"_0":"file:///â€¦"}}
PLACEMENT_CASE=$(printf '%s' "$PROJECT_DATA" | jq -r '.worktreePlacement | keys[0]')

# Tokenize the command, then walk left-to-right after the `add` verb
# pulling out `-b <branch>` / `--branch=<branch>` and the first
# positional path. Bash 4+ `read -ra` handles the splitting.
BRANCH=""
in_args=0
prev=""
read -ra TOKENS <<< "$COMMAND"
for tok in "${TOKENS[@]}"; do
  if [ $in_args -eq 0 ]; then
    if [ "$prev" = "worktree" ] && [ "$tok" = "add" ]; then
      in_args=1
    fi
    prev="$tok"
    continue
  fi
  case "$tok" in
    -b|-B)
      prev="$tok"
      ;;
    --branch=*)
      BRANCH="${tok#--branch=}"
      prev=""
      ;;
    -*)
      prev=""
      ;;
    *)
      if [ "$prev" = "-b" ] || [ "$prev" = "-B" ]; then
        BRANCH="$tok"
      fi
      prev=""
      ;;
  esac
done

if [ -z "$BRANCH" ]; then
  # Without `-b/-B/--branch` we don't know what branch the agent
  # wanted. Naming on its behalf would be noisier than just letting
  # the original command run, so passthrough.
  exit 0
fi

# Mirror `Project.resolvedWorktreeURL(branchLeaf:)`.
BRANCH_LEAF="${BRANCH##*/}"
case "$PLACEMENT_CASE" in
  siblingPrefixed)
    REPO_BASENAME="$(basename "$PROJECT_ROOT")"
    WORKTREE_PATH="$(dirname "$PROJECT_ROOT")/${REPO_BASENAME}-${BRANCH_LEAF}"
    ;;
  insideHidden)
    WORKTREE_PATH="$PROJECT_ROOT/.worktrees/$BRANCH_LEAF"
    ;;
  custom)
    CUSTOM_PARENT=$(printf '%s' "$PROJECT_DATA" \
      | jq -r '.worktreePlacement.custom._0 // empty | sub("^file://"; "")')
    if [ -z "$CUSTOM_PARENT" ]; then
      exit 0
    fi
    WORKTREE_PATH="$CUSTOM_PARENT/$BRANCH_LEAF"
    ;;
  *)
    # Unknown placement case â€” passthrough rather than guess.
    exit 0
    ;;
esac

# Run `git worktree add` ourselves. Suppress its stdout so our own
# stderr remains the only signal Claude reads. If `git` fails we
# passthrough â€” letting the original command surface the failure is
# better than swallowing it.
mkdir -p "$(dirname "$WORKTREE_PATH")"
if ! git -C "$PROJECT_ROOT" worktree add -b "$BRANCH" "$WORKTREE_PATH" >/dev/null 2>&1; then
  exit 0
fi

# Walk the bootstrap array. Items can be either a bare string or an
# object `{cmd, timeout?, cwd?}` (Swift's `BootstrapItem` `oneOf`).
BOOTSTRAP_JSON=$(printf '%s' "$PROJECT_DATA" | jq -c '.bootstrap // []')
BOOTSTRAP_COUNT=$(printf '%s' "$BOOTSTRAP_JSON" | jq 'length')

# NOTE: `item.timeout` from `BootstrapDetail` is read into local memory
# below but NOT enforced in v1 â€” a hung step keeps `eval` blocking until
# Claude's own PreToolUse 600s hook ceiling kills the parent. A follow-up
# will pipe each step through `gtimeout` (coreutils) or BSD `timeout` so
# the JSON schema and runtime stay in sync.
if [ "$BOOTSTRAP_COUNT" -gt 0 ]; then
  i=0
  while [ "$i" -lt "$BOOTSTRAP_COUNT" ]; do
    ITEM=$(printf '%s' "$BOOTSTRAP_JSON" | jq -c ".[$i]")
    if printf '%s' "$ITEM" | jq -e 'type == "string"' >/dev/null 2>&1; then
      CMD=$(printf '%s' "$ITEM" | jq -r '.')
      STEP_CWD=""
    else
      CMD=$(printf '%s' "$ITEM" | jq -r '.cmd')
      STEP_CWD=$(printf '%s' "$ITEM" | jq -r '.cwd // empty')
    fi
    # Refuse to follow `..` segments out of the worktree. State.json
    # is per-machine today, but the same shape is what a future
    # team-shared `.limpid/project.json` would carry, so we treat
    # `cwd` as untrusted from day one.
    case "$STEP_CWD" in
      /*|../*|*/../*|*/..|..)
        echo "limpid-pretool-worktree-hook: skipping step â€” unsafe cwd '$STEP_CWD'" >&2
        i=$((i + 1))
        continue
        ;;
    esac
    STEP_DIR="$WORKTREE_PATH"
    [ -n "$STEP_CWD" ] && STEP_DIR="$WORKTREE_PATH/$STEP_CWD"
    # Bootstrap-step failures are diagnostic, not fatal. Surface to
    # stderr so the user can see what went wrong, then continue so
    # the rest of the steps still try.
    ( cd "$STEP_DIR" && eval "$CMD" ) >&2 || true
    i=$((i + 1))
  done
fi

# Notify the app so `WorktreeEventTracker` can fire a GitSync refetch.
NOTIFY_DIR="$LIMPID_AGENT_STATES_DIR/worktree-events"
mkdir -p "$NOTIFY_DIR" 2>/dev/null || true
# BSD `date` doesn't understand `%N`, so we combine `%s` with `$$` and
# `$RANDOM` to keep filenames unique across rapid back-to-back creates.
# Without this two same-second events would clobber each other and the
# tracker would lose one.
EVENT_FILE="$NOTIFY_DIR/$(date +%s)-$$-$RANDOM-create.json"
# Write through a tempfile + atomic rename so the tracker can never
# observe a half-flushed file mid-scan. A naive `> "$EVENT_FILE"` is
# openâ†’writeâ†’close (not atomic); the tracker would parse partial JSON,
# log a warning, and delete the event â€” silently losing it.
jq -n \
  --arg event "WorktreeCreate" \
  --arg repoRoot "$PROJECT_ROOT" \
  --arg worktreePath "$WORKTREE_PATH" \
  --arg branch "$BRANCH" \
  '{event: $event, repoRoot: $repoRoot, worktreePath: $worktreePath, branch: $branch}' \
  > "${EVENT_FILE}.tmp" 2>/dev/null \
  && mv "${EVENT_FILE}.tmp" "$EVENT_FILE" 2>/dev/null \
  || true

# Keep the stderr line terse: Claude reads it as context, and a long
# message tempts the model to "summarise" it back to the user with
# extra commentary the user didn't ask for. The worktree path is the
# only thing the model needs to know in order to continue.
echo "Limpid created worktree at $WORKTREE_PATH." >&2
exit 2
