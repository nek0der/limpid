#!/bin/sh
# Limpid claude hook receiver — invoked by Claude Code on every hook
# event we subscribe to (SessionStart, UserPromptSubmit, PreToolUse,
# Notification, PreCompact, Stop, StopFailure, SessionEnd). Keyed by
# LIMPID_PANE_ID (= split-tree leaf UUID, one per pane).
#
# Two persistence paths:
#   - $LIMPID_SESSIONS_DIR/<pane>.json — session id for `claude --resume`.
#     Authoritative on SessionStart, dropped on user-initiated SessionEnd
#     (reason ∈ clear/logout/exit/prompt_input_exit/quit).
#   - $LIMPID_AGENT_STATES_DIR/<pane>.state.json — agent lifecycle state
#     for the L1/L2 status icons. Rewritten on every hook event so
#     `Tab.claudeAgentBadges[paneID]` mirrors the current lifecycle.
#
# Failure policy: ALWAYS exit 0. A broken hook must never block Claude
# from running. We drop stderr to /dev/null in production so the hook
# is observably silent; tooling that needs diagnostics can set
# LIMPID_HOOK_LOG=<path> to capture stderr into a file.

set -u

if [ -n "${LIMPID_HOOK_LOG:-}" ]; then
  exec 2>>"$LIMPID_HOOK_LOG" || exec 2>/dev/null
else
  exec 2>/dev/null
fi

payload="$(cat 2>/dev/null || true)"

pane_id="${LIMPID_PANE_ID:-}"
# Accept only UUID-shaped pane ids (hex + dash + max 64 chars) so a
# hostile env can't traverse the filesystem via crafted PANE_ID values.
case "$pane_id" in
  '') exit 0 ;;
  *[!0-9A-Fa-f-]*) exit 0 ;;
esac
[ "${#pane_id}" -le 64 ] || exit 0

sessions_dir="${LIMPID_SESSIONS_DIR:-$HOME/Library/Application Support/Limpid/sessions}"
states_dir="${LIMPID_AGENT_STATES_DIR:-$HOME/Library/Application Support/Limpid/agent-states}"
mkdir -p "$sessions_dir" 2>/dev/null
mkdir -p "$states_dir" 2>/dev/null

# Extract fields out of the JSON payload with sed. We intentionally
# avoid jq — it's not in the base macOS install and we don't want a
# runtime dependency for a hook that must never fail.
extract() {
  printf '%s' "$payload" | sed -n 's/.*"'"$1"'"[[:space:]]*:[[:space:]]*"\([^"\\]*\)".*/\1/p' | head -n1
}
extract_int() {
  printf '%s' "$payload" | sed -n 's/.*"'"$1"'"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n1
}

session_id="$(extract session_id)"
cwd="$(extract cwd)"
hook_event="$(extract hook_event_name)"
reason="$(extract reason)"
tool_name="$(extract tool_name)"
notification_type="$(extract notification_type)"
notification_message="$(extract message)"
# AskUserQuestion's tool_input carries the question text under a
# `question` field. Pull whichever string-shaped `question` field is
# in the payload — depth-agnostic sed because the value usually
# lives nested inside `tool_input.question`.
ask_question="$(extract question)"
error_type="$(extract error_type)"
current_token_count="$(extract_int current_token_count)"

ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

# Strip control chars / quotes from values that we emit verbatim into
# JSON. Belt-and-suspenders — the extract regex already excludes
# `"` and `\` but we re-check before write.
sanitize() {
  case "$1" in
    *[\"\\]*) printf '%s' "" ;;
    *) printf '%s' "$1" ;;
  esac
}
cwd_safe="$(sanitize "$cwd")"
tool_safe="$(sanitize "$tool_name")"
error_safe="$(sanitize "$error_type")"
message_safe="$(sanitize "$notification_message")"
question_safe="$(sanitize "$ask_question")"
detail_safe=""
# Carried into the OSC 2 tab-title fallback below. Initialised here so
# the title block can reference it even on events that skip the state
# write (defensive under `set -u`).
first_prompt=""

# Compute the lifecycle state for the L1/L2 status icons. Order
# matters: AskUserQuestion is a PreToolUse subtype but maps to
# `.needsInput`, so check it before the generic running branch.
new_state=""
case "$hook_event" in
  SessionStart)
    new_state="idle"
    ;;
  UserPromptSubmit)
    new_state="running"
    ;;
  PreToolUse)
    if [ "$tool_safe" = "AskUserQuestion" ]; then
      new_state="needsInput"
      # Use the actual question text when we managed to extract it;
      # fall back to the tool name so the user at least knows *which*
      # tool blocked. The Limpid notification body and the L2 tooltip
      # both read this field.
      if [ -n "$question_safe" ]; then
        detail_safe="$question_safe"
      else
        detail_safe="AskUserQuestion"
      fi
    else
      new_state="running"
      detail_safe="$tool_safe"
    fi
    ;;
  Notification)
    # Only `permission_prompt` requires user attention. `idle_prompt`,
    # `auth_success`, `elicitation_dialog` etc are noise from a
    # status-icon perspective (cmux #1027 root cause).
    case "$notification_type" in
      permission_prompt)
        new_state="needsInput"
        # Use the payload's `message` (e.g. "Allow Bash command:
        # rm -rf node_modules ?") so the Limpid-emitted notification
        # has the actual prompt instead of a generic "permission"
        # placeholder. Fall back to "permission" when the message
        # field was empty / unparseable.
        if [ -n "$message_safe" ]; then
          detail_safe="$message_safe"
        else
          detail_safe="permission"
        fi
        ;;
      *)
        new_state=""
        ;;
    esac
    ;;
  PreCompact)
    new_state="compacting"
    ;;
  Stop)
    new_state="idle"
    ;;
  StopFailure)
    new_state="error"
    detail_safe="$error_safe"
    ;;
  SessionEnd)
    new_state="unknown"
    ;;
esac

if [ -n "$new_state" ]; then
  state_final="$states_dir/$pane_id.state.json"
  state_tmp="$states_dir/.$pane_id.state.json.tmp.$$"
  # `runStartedAt` is set at UserPromptSubmit and cleared on Stop /
  # SessionStart / SessionEnd so the L2 tooltip can compute elapsed
  # seconds without extra bookkeeping. `lastPrompt` follows the same
  # carry-through model — captured at UserPromptSubmit so the Stop
  # notification body can say *what* finished, not just *that*
  # something finished. We re-read the previous file each event so
  # PreToolUse / Notification / PreCompact preserve both fields.
  prev_run_started=""
  prev_last_prompt=""
  prev_first_prompt=""
  prev_session_started=""
  if [ -f "$state_final" ]; then
    prev_run_started="$(sed -n 's/.*"runStartedAt"[[:space:]]*:[[:space:]]*"\([^"\\]*\)".*/\1/p' "$state_final" 2>/dev/null | head -n1)"
    prev_last_prompt="$(sed -n 's/.*"lastPrompt"[[:space:]]*:[[:space:]]*"\([^"\\]*\)".*/\1/p' "$state_final" 2>/dev/null | head -n1)"
    prev_first_prompt="$(sed -n 's/.*"firstPrompt"[[:space:]]*:[[:space:]]*"\([^"\\]*\)".*/\1/p' "$state_final" 2>/dev/null | head -n1)"
    prev_session_started="$(sed -n 's/.*"sessionStartedAt"[[:space:]]*:[[:space:]]*"\([^"\\]*\)".*/\1/p' "$state_final" 2>/dev/null | head -n1)"
  fi
  case "$hook_event" in
    UserPromptSubmit)
      run_started="$ts"
      # Extract the user's prompt from this event's payload so the
      # next Stop hook's notification body can reference it. sed is
      # fragile against embedded quotes / newlines / escapes — typical
      # prompts work, edge cases truncate to whatever sed could match,
      # and the notification falls back to a generic string when the
      # extracted text is empty. Good enough for MVP.
      raw_prompt="$(printf '%s' "$payload" | sed -n 's/.*"prompt"[[:space:]]*:[[:space:]]*"\([^"\\]*\)".*/\1/p' | head -n1)"
      last_prompt="$(sanitize "$raw_prompt")"
      # `firstPrompt` is the seed for the tab-title fallback: captured
      # once at the session's first prompt and never overwritten, so a
      # later turn still resolves to the conversation's opening line
      # when Claude hasn't generated an `ai-title` yet. (`lastPrompt`
      # is overwritten every turn and would drift off-topic.)
      if [ -n "$prev_first_prompt" ]; then
        first_prompt="$prev_first_prompt"
      else
        first_prompt="$last_prompt"
      fi
      session_started="$prev_session_started"
      ;;
    SessionStart)
      run_started=""
      last_prompt=""
      first_prompt=""
      # `sessionStartedAt` is captured here and held for every event of
      # this session. The Swift side uses it to decide which pane "owns"
      # the tab title when more than one Claude/Codex session is alive:
      # the latest SessionStart wins, so a fresh session in pane 2
      # doesn't get clobbered when pane 1's older session emits a turn.
      session_started="$ts"
      ;;
    Stop|SessionEnd|StopFailure)
      run_started=""
      # Stop keeps `lastPrompt` so the Tracker's diff (running→idle)
      # can read it once before the next UserPromptSubmit overwrites.
      # SessionEnd resets; StopFailure is fatal so also reset.
      if [ "$hook_event" = "Stop" ]; then
        last_prompt="$prev_last_prompt"
      else
        last_prompt=""
      fi
      # Keep the captured opening prompt across Stop so the title block
      # can fall back to it; SessionEnd / StopFailure reset it
      # alongside the rest of the per-run state.
      if [ "$hook_event" = "Stop" ]; then
        first_prompt="$prev_first_prompt"
        session_started="$prev_session_started"
      else
        first_prompt=""
        session_started=""
      fi
      ;;
    *)
      run_started="$prev_run_started"
      last_prompt="$prev_last_prompt"
      first_prompt="$prev_first_prompt"
      session_started="$prev_session_started"
      ;;
  esac
  tokens_field=""
  if [ -n "$current_token_count" ]; then
    tokens_field=",\"contextTokens\":$current_token_count"
  fi
  pid_field=""
  if [ -n "${LIMPID_CLAUDE_PID:-}" ]; then
    pid_field=",\"pid\":\"$LIMPID_CLAUDE_PID\""
  fi
  prompt_field=""
  if [ -n "$last_prompt" ]; then
    prompt_field=",\"lastPrompt\":\"$last_prompt\""
  fi
  first_prompt_field=""
  if [ -n "$first_prompt" ]; then
    first_prompt_field=",\"firstPrompt\":\"$first_prompt\""
  fi
  session_started_field=""
  if [ -n "$session_started" ]; then
    session_started_field=",\"sessionStartedAt\":\"$session_started\""
  fi
  {
    printf '{"schemaVersion":1,"paneId":"%s","state":"%s","detail":"%s","runStartedAt":"%s","updatedAt":"%s","lastHookEvent":"%s"%s%s%s%s%s}\n' \
      "$pane_id" \
      "$new_state" \
      "$detail_safe" \
      "$run_started" \
      "$ts" \
      "$hook_event" \
      "$tokens_field" \
      "$pid_field" \
      "$prompt_field" \
      "$first_prompt_field" \
      "$session_started_field"
  } > "$state_tmp" 2>/dev/null && mv -f "$state_tmp" "$state_final" 2>/dev/null || rm -f "$state_tmp" 2>/dev/null
fi

# ----- Tab title (Claude's title / opening prompt -> OSC 2) -----
# Drive the tab label off whatever best names this conversation, in
# the same precedence Claude's own resume picker uses:
#   customTitle (explicit /rename)  >  aiTitle (Haiku auto-name)
#   >  firstPrompt (the session's opening line, captured above)
# Claude writes `customTitle` / `aiTitle` into an `ai-title` line in
# the transcript jsonl, but only generates `aiTitle` sporadically and
# late — so without the firstPrompt fallback a fresh pane would keep
# showing the launch command for the whole session. We hand the
# resolved title to Claude as an OSC 2 escape via the hook's
# `terminalSequence` output; Claude emits it on our behalf through its
# own terminal write path (race-free, tmux/screen-safe), and
# libghostty turns it into a GHOSTTY_ACTION_SET_TITLE that Limpid
# already routes to the tab label.
#
# We force `LC_ALL=C` so sed treats each line as bytes — a Japanese
# title would otherwise crash BSD sed with "illegal byte sequence".
# `null` / empty values don't match the quoted-capture regex, so they
# fall through to the next candidate.
case "$hook_event" in
  UserPromptSubmit | Stop)
    ai_title=""
    custom_title=""
    transcript_path="$(extract transcript_path)"
    if [ -n "$transcript_path" ] && [ -f "$transcript_path" ]; then
      title_line="$(grep '"type":"ai-title"' "$transcript_path" 2>/dev/null | tail -n1)"
      if [ -n "$title_line" ]; then
        ai_title="$(printf '%s' "$title_line" | LC_ALL=C sed -n 's/.*"aiTitle"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
        custom_title="$(printf '%s' "$title_line" | LC_ALL=C sed -n 's/.*"customTitle"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
      fi
    fi
    tab_title="${custom_title:-${ai_title:-$first_prompt}}"
    if [ -n "$tab_title" ]; then
      # JSON-escape backslash + double-quote and drop any control
      # bytes before splicing into the terminalSequence string.
      esc_title="$(printf '%s' "$tab_title" | LC_ALL=C sed 's/\\/\\\\/g; s/"/\\"/g' | LC_ALL=C tr -d '\000-\037')"
      printf '{"terminalSequence":"\\u001b]2;%s\\u0007"}\n' "$esc_title"
    fi
    ;;
esac

# ----- Session record (claude --resume) -----
# Independent of the lifecycle state file above; SessionStart writes
# the record, user-initiated SessionEnd drops it. Other events are
# no-ops on this path.
if [ "$hook_event" = "SessionEnd" ]; then
  case "$reason" in
    clear|logout|exit|prompt_input_exit|quit)
      rm -f "$sessions_dir/$pane_id.json" 2>/dev/null
      ;;
    *)
      # SIGTERM-driven end or any reason we don't recognise. Keep
      # the record so Limpid's next launch can auto-resume.
      :
      ;;
  esac
  exit 0
fi

# Only write a session record when SessionStart fires (we have a real
# session_id we want to remember). Other events would write stale
# data — the existing record is the authority for resume.
if [ "$hook_event" != "SessionStart" ]; then
  exit 0
fi

case "$session_id" in
  '') exit 0 ;;
  *[\"\\]*) exit 0 ;;
esac

session_final="$sessions_dir/$pane_id.json"
session_tmp="$sessions_dir/.$pane_id.json.tmp.$$"

{
  printf '{"schemaVersion":1,"paneId":"%s","sessionId":"%s","cwd":"%s","updatedAt":"%s","lastHookEvent":"%s"}\n' \
    "$pane_id" "$session_id" "$cwd_safe" "$ts" "$hook_event"
} > "$session_tmp" 2>/dev/null || exit 0

mv -f "$session_tmp" "$session_final" 2>/dev/null || rm -f "$session_tmp" 2>/dev/null

exit 0
